# ============================================
# MSI QUOTE STUDIO ENVIRONMENT VARIABLES
# ============================================
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local — it contains secrets.

# ============================================
# DATABASE — SUPABASE
# ============================================
# Supabase project URL (public)
# Format: https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co

# Anon / publishable key (public, safe to expose)
# Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ⚠️ Server-only — bypasses RLS, never expose to the browser
# Dashboard → Project Settings → API → "service_role" secret
SUPABASE_SERVICE_ROLE_KEY=

# Postgres connection string used by Better Auth's pg.Pool
# Dashboard → Project Settings → Database → "Transaction pooler" (port 6543)
# Format: postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
DATABASE_URL=

# ============================================
# AUTHENTICATION — BETTER AUTH
# ============================================
# 32+ char random string. Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# In production: the deployed Cloudflare Pages URL (e.g. https://msi-quote-studio.pages.dev)
# In local dev:  http://localhost:3000
BETTER_AUTH_URL=

# ============================================
# AI INFERENCE — GROQ (free tier)
# ============================================
# Sign up at https://console.groq.com — generate at https://console.groq.com/keys
GROQ_API_KEY=

# ============================================
# APP CONFIGURATION
# ============================================
# Public-facing canonical URL (used by metadata, OG tags, redirects)
# Production: https://msi-quote-studio.pages.dev
# Local dev:  http://localhost:3000
NEXT_PUBLIC_APP_URL=

# ============================================
# SCHEDULED JOBS — VERCEL CRON
# ============================================
# Shared secret Vercel includes as `Authorization: Bearer <CRON_SECRET>`
# when invoking routes listed under `crons` in vercel.json. The
# /api/cron/cleanup-demo handler rejects requests without it.
# Generate with: openssl rand -base64 32
CRON_SECRET=

# ============================================
# TRANSACTIONAL EMAIL — BREVO (free tier)
# ============================================
# Used to email branded quote PDFs to customers from the quote detail
# page. If unset, the Email-customer button is disabled with a tooltip.
#
# Setup (~5 minutes, no card required):
#   1. Sign up at https://www.brevo.com (free tier: 300 emails/day)
#   2. Settings → Senders, Domains & Dedicated IPs → Senders → Add a sender
#      Verify the email address you want quotes to come FROM (Brevo emails
#      you a confirmation link). For domains, add SPF/DKIM records but
#      verifying just one sender email is enough for the demo.
#   3. Settings → SMTP & API → API Keys → Generate a new API key
BREVO_API_KEY=

# Verified sender email (must match a sender you confirmed in Brevo).
BREVO_SENDER_EMAIL=

# Display name shown to recipients (e.g. "Samuel @ MSI Quote Studio").
BREVO_SENDER_NAME=
